<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <parent>
    <groupId>com.ty</groupId>
    <artifactId>native-spring-server-bridge-parent</artifactId>
    <version>0.9.3</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <artifactId>native-spring-server-bridge</artifactId>
  <packaging>jar</packaging>

  <dependencies>
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-autoconfigure</artifactId>
    </dependency>
  </dependencies>

  <build>
    <resources>
      <resource>
        <directory>${project.basedir}/target/generated-classes/cloudlogger-swig</directory>
        <includes>
          <include>**/*.class</include>
        </includes>
      </resource>
      <resource>
        <directory>${project.basedir}/target/native</directory>
        <targetPath>native</targetPath>
        <includes>
          <include>lib/**</include>
        </includes>
      </resource>
    </resources>
  </build>
</project>